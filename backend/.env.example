# Mai comitegis el fitxer .env real — aquest fitxer és només un exemple
# Genera SECRET_KEY i REFRESH_SECRET_KEY amb: openssl rand -hex 32

# --- Base de dades ---
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/dbname
# Staging (Railway): postgresql+asyncpg://user:password@host.railway.internal:5432/railway

# --- Entorn ---
ENVIRONMENT=development
# Staging: production

# --- Seguretat ---
SECRET_KEY=canvia-per-un-secret-de-256-bits
REFRESH_SECRET_KEY=canvia-per-un-altre-secret-de-256-bits

# --- Supabase ---
SUPABASE_URL=https://el-teu-projecte.supabase.co
SUPABASE_ANON_KEY=la-teva-anon-key
SUPABASE_SERVICE_KEY=la-teva-service-role-key

# --- CORS ---
ALLOWED_ORIGINS=["http://localhost:3000","capacitor://localhost"]
# Staging: ["https://staging.tuapp.vercel.app"]

# --- Monitoratge ---
SENTRY_DSN=
